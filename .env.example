# Local compose baseline.

VITE_API_BASE_URL=http://localhost:8000
O3DE_CONTROL_PLANE_DB_PATH=./runtime/control_plane.sqlite3

# Explicit local O3DE target for this repo. Keep these pinned to the active
# project and engine you want the control plane to operate against.
O3DE_TARGET_PROJECT_ROOT=C:\Users\topgu\O3DE\Projects\McpSandbox
O3DE_TARGET_ENGINE_ROOT=C:\src\o3de
O3DE_TARGET_EDITOR_RUNNER=C:\Users\topgu\O3DE\Projects\McpSandbox\build\windows\bin\profile\Editor.exe

# Optional explicit editor runtime override. If unset, the runtime falls back
# to O3DE_TARGET_EDITOR_RUNNER instead of any archived project state.
O3DE_EDITOR_SCRIPT_RUNNER=

# Frontend defaults should mirror the backend target so prompt and dispatch
# forms prefill the same active project intentionally.
VITE_O3DE_TARGET_PROJECT_ROOT=C:\Users\topgu\O3DE\Projects\McpSandbox
VITE_O3DE_TARGET_ENGINE_ROOT=C:\src\o3de

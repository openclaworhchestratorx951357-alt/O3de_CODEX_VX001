{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/render.capture.viewport.artifact-metadata.schema.json",
  "title": "render.capture.viewport artifact metadata",
  "allOf": [
    {
      "$ref": "./render.capture.viewport.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "render.capture.viewport" },
        "agent": { "const": "render-lookdev" },
        "execution_mode": {
          "type": "string",
          "enum": ["simulated", "real"]
        }
      }
    }
  ]
}

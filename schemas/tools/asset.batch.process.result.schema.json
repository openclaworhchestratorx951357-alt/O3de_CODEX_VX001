{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/asset.batch.process.result.schema.json",
  "title": "asset.batch.process result",
  "allOf": [
    { "$ref": "../dispatch-result.schema.json" },
    {
      "type": "object",
      "properties": {
        "tool": { "const": "asset.batch.process" },
        "approval_class": { "const": "build_execute" },
        "execution_mode": { "enum": ["simulated", "real"] },
        "simulated": { "type": "boolean" }
      }
    }
  ]
}

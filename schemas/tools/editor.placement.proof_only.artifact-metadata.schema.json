{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/editor.placement.proof_only.artifact-metadata.schema.json",
  "title": "editor.placement.proof_only artifact metadata",
  "allOf": [
    {
      "$ref": "./editor.placement.proof_only.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "editor.placement.proof_only" },
        "agent": { "const": "editor-control" },
        "execution_mode": { "enum": ["simulated", "real"] }
      }
    }
  ]
}

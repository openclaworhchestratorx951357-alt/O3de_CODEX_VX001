{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/asset.batch.process.execution-details.schema.json",
  "title": "asset.batch.process execution details",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "inspection_surface",
    "execution_boundary",
    "simulated"
  ],
  "properties": {
    "inspection_surface": {
      "type": "string",
      "enum": ["simulated", "asset_batch_preflight"]
    },
    "execution_boundary": { "type": "string", "minLength": 1 },
    "simulated": { "type": "boolean" },
    "adapter_family": { "type": "string", "minLength": 1 },
    "adapter_mode": { "type": "string", "minLength": 1 },
    "adapter_contract_version": { "type": "string", "minLength": 1 },
    "real_path_available": { "type": "boolean" },
    "preflight_execution_mode": { "type": "string", "minLength": 1 },
    "batch_request_explicit": { "type": "boolean" },
    "project_root_path": { "type": "string", "minLength": 1 },
    "source_glob_input": { "type": "string", "minLength": 1 },
    "source_glob_normalized": { "type": "string", "minLength": 1 },
    "source_glob_scope": { "type": "string", "minLength": 1 },
    "source_glob_within_project_root": { "type": "boolean" },
    "source_candidate_match_count": { "type": "integer", "minimum": 0 },
    "resolved_source_candidate_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "source_candidate_relative_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "platform_request_explicit": { "type": "boolean" },
    "platforms_requested": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "clean_requested": { "type": "boolean" },
    "max_jobs_requested": { "type": ["integer", "null"], "minimum": 1 },
    "runtime_probe_attempted": { "type": "boolean" },
    "runtime_probe_method": { "type": "string", "minLength": 1 },
    "runtime_probe_available": { "type": "boolean" },
    "runtime_probe_error": { "type": ["string", "null"] },
    "runtime_status": { "type": "string", "minLength": 1 },
    "runtime_available": { "type": "boolean" },
    "runtime_process_count": { "type": "integer", "minimum": 0 },
    "runtime_process_ids": {
      "type": "array",
      "items": { "type": "integer" }
    },
    "runtime_process_names": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "inspection_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unavailable_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "execution_attempted": { "type": "boolean" },
    "result_artifact_produced": { "type": "boolean" },
    "result_artifact_path": { "type": ["string", "null"] },
    "result_artifact_content_type": { "type": ["string", "null"] },
    "result_artifact_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "exit_code_available": { "type": "boolean" },
    "exit_code": { "type": ["integer", "null"] },
    "result_status": { "type": "string", "minLength": 1 },
    "result_summary_available": { "type": "boolean" },
    "result_unavailable_reason": { "type": ["string", "null"] },
    "batch_unavailable_reason": { "type": ["string", "null"] },
    "fallback_category": { "type": "string", "minLength": 1 },
    "fallback_reason": { "type": "string", "minLength": 1 }
  }
}

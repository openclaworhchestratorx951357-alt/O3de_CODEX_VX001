{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/asset.source.inspect.execution-details.schema.json",
  "title": "asset.source.inspect execution details",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "inspection_surface",
    "execution_boundary",
    "simulated"
  ],
  "properties": {
    "inspection_surface": {
      "type": "string",
      "enum": ["simulated", "asset_source_file"]
    },
    "execution_boundary": { "type": "string", "minLength": 1 },
    "simulated": { "type": "boolean" },
    "adapter_family": { "type": "string", "minLength": 1 },
    "adapter_mode": { "type": "string", "minLength": 1 },
    "adapter_contract_version": { "type": "string", "minLength": 1 },
    "real_path_available": { "type": "boolean" },
    "fallback_category": { "type": "string", "minLength": 1 },
    "fallback_reason": { "type": "string", "minLength": 1 },
    "project_root_path": { "type": "string", "minLength": 1 },
    "project_root": { "type": "string", "minLength": 1 },
    "project_json_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "project_name": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "cache_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "database_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "asset_database_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "asset_database_read_mode": {
      "type": "string",
      "enum": ["read-only"]
    },
    "available_platforms": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "selected_platform": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "catalog_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "original_source_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "normalized_source_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "read_only": { "type": "boolean" },
    "mutation_occurred": { "type": "boolean" },
    "readiness_status": {
      "type": "string",
      "enum": [
        "project_root_missing",
        "project_json_missing",
        "asset_cache_missing",
        "asset_database_missing",
        "platform_cache_missing",
        "asset_catalog_missing",
        "source_asset_path_missing",
        "source_asset_path_escapes_project",
        "source_asset_not_checked_yet",
        "schema_mismatch",
        "ready_for_asset_source_inspect"
      ]
    },
    "proof_status": {
      "type": "string",
      "enum": [
        "project_root_missing",
        "project_json_missing",
        "asset_cache_missing",
        "asset_database_missing",
        "platform_cache_missing",
        "asset_catalog_missing",
        "source_not_found",
        "product_not_found",
        "schema_mismatch",
        "unsafe_source_path",
        "ready_for_asset_source_inspect",
        "asset_source_inspect_proven"
      ]
    },
    "blocked_reason": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "source_path_input": { "type": "string", "minLength": 1 },
    "source_path_resolved": { "type": "string", "minLength": 1 },
    "source_path_relative_to_project_root": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "source_path_source_of_truth": { "type": "string", "minLength": 1 },
    "source_path_within_project_root": { "type": "boolean" },
    "source_read_mode": { "type": "string", "minLength": 1 },
    "source_exists": { "type": "boolean" },
    "source_is_file": { "type": "boolean" },
    "source_resolution_status": { "type": "string", "minLength": 1 },
    "source_name": { "type": "string", "minLength": 1 },
    "source_extension": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "source_size_bytes": {
      "type": ["integer", "null"],
      "minimum": 0
    },
    "source_sha256": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "source_id": {
      "type": ["integer", "null"]
    },
    "source_guid": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "include_flags": {
      "type": "object",
      "additionalProperties": { "type": "boolean" }
    },
    "inspection_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unavailable_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "products": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "product_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "product_id": { "type": "integer" },
          "product_path": { "type": "string", "minLength": 1 },
          "sub_id": { "type": ["integer", "null"] },
          "hash": { "type": ["integer", "null"] },
          "platform": { "type": "string", "minLength": 1 },
          "job_status": { "type": ["integer", "null"] },
          "job_key": { "type": "string", "minLength": 1 },
          "fingerprint": { "type": ["integer", "null"] },
          "last_log_time": { "type": ["integer", "null"] },
          "source_guid": { "type": "string", "minLength": 1 }
        }
      }
    },
    "product_path": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "product_id": {
      "type": ["integer", "null"]
    },
    "product_sub_id": {
      "type": ["integer", "null"]
    },
    "product_count": { "type": "integer", "minimum": 0 },
    "product_evidence_requested": { "type": "boolean" },
    "product_evidence_available": { "type": "boolean" },
    "product_evidence_source": { "type": "string", "minLength": 1 },
    "product_unavailable_reason": { "type": "string", "minLength": 1 },
    "asset_catalog_evidence_requested": { "type": "boolean" },
    "asset_catalog_evidence_available": { "type": "boolean" },
    "asset_catalog_evidence_source": { "type": "string", "minLength": 1 },
    "asset_catalog_unavailable_reason": { "type": "string", "minLength": 1 },
    "asset_catalog_product_path_presence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "asset_catalog_product_path_count": { "type": "integer", "minimum": 0 },
    "catalog_presence": { "type": "boolean" },
    "asset_catalog_path": { "type": "string", "minLength": 1 },
    "asset_catalog_size_bytes": { "type": "integer", "minimum": 0 },
    "asset_catalog_sha256": { "type": "string", "minLength": 1 },
    "asset_catalog_last_write_time": { "type": "number" },
    "asset_catalog_read_mode": {
      "type": "string",
      "enum": ["read-only"]
    },
    "asset_catalog_format_observed": {
      "type": "string",
      "enum": ["binary-or-serialized"]
    },
    "asset_catalog_parser_limit": { "type": "integer", "minimum": 1 },
    "dependencies": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "dependency_rows": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "product_id": { "type": "integer" },
          "platform": { "type": "string", "minLength": 1 },
          "dependency_source_guid": { "type": "string", "minLength": 1 },
          "dependency_sub_id": { "type": ["integer", "null"] },
          "dependency_flags": { "type": ["integer", "null"] },
          "from_asset_id": { "type": ["integer", "null"] },
          "unresolved_path": { "type": "string" },
          "unresolved_dependency_type": { "type": ["integer", "null"] }
        }
      }
    },
    "dependency_count": { "type": "integer", "minimum": 0 },
    "dependency_evidence_requested": { "type": "boolean" },
    "dependency_evidence_available": { "type": "boolean" },
    "dependency_evidence_source": { "type": "string", "minLength": 1 },
    "dependency_unavailable_reason": { "type": "string", "minLength": 1 },
    "asset_database_freshness_status": {
      "type": "string",
      "enum": ["fresh_enough_for_readback", "stale_or_unverified", "unknown", "missing"]
    },
    "asset_catalog_freshness_status": {
      "type": "string",
      "enum": ["fresh_enough_for_readback", "stale_or_unverified", "unknown", "missing"]
    },
    "asset_processor_rerun_required": { "type": "boolean" },
    "safest_next_step": { "type": "string", "minLength": 1 },
    "operator_approval_state": {
      "type": "string",
      "enum": ["not_requested", "pending", "approved", "rejected"]
    },
    "missing_substrate_guidance": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "asset_readback_review_packet": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "capability": { "type": "string", "const": "asset.source.inspect" },
        "review_contract_version": { "type": "string", "minLength": 1 },
        "readiness_status": { "type": "string", "minLength": 1 },
        "proof_status": { "type": "string", "minLength": 1 },
        "read_only": { "type": "boolean" },
        "mutation_occurred": { "type": "boolean" },
        "selected_project": {
          "type": "object",
          "additionalProperties": true
        },
        "selected_platform": {
          "type": "object",
          "additionalProperties": true
        },
        "asset_database": {
          "type": "object",
          "additionalProperties": true
        },
        "source": {
          "type": "object",
          "additionalProperties": true
        },
        "products": {
          "type": "object",
          "additionalProperties": true
        },
        "dependencies": {
          "type": "object",
          "additionalProperties": true
        },
        "catalog": {
          "type": "object",
          "additionalProperties": true
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        },
        "blocked_reason": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "missing_substrate_guidance": {
          "type": ["string", "null"],
          "minLength": 1
        },
        "safest_next_step": { "type": "string", "minLength": 1 },
        "operator_approval_state": {
          "type": "string",
          "enum": ["not_requested", "pending", "approved", "rejected"]
        },
        "forge_handoff": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}

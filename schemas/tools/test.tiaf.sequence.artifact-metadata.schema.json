{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/test.tiaf.sequence.artifact-metadata.schema.json",
  "title": "test.tiaf.sequence artifact metadata",
  "allOf": [
    {
      "$ref": "./test.tiaf.sequence.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "test.tiaf.sequence" },
        "agent": { "const": "validation" },
        "execution_mode": {
          "type": "string",
          "enum": ["simulated", "real"]
        }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/project.inspect.artifact-metadata.schema.json",
  "title": "project.inspect artifact metadata",
  "allOf": [
    {
      "$ref": "./project.inspect.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "project.inspect" },
        "agent": { "const": "project-build" },
        "execution_mode": {
          "type": "string",
          "enum": ["simulated", "real"]
        }
      }
    }
  ]
}

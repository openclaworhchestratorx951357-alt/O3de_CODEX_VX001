{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/settings.patch.artifact-metadata.schema.json",
  "title": "settings.patch artifact metadata",
  "allOf": [
    {
      "$ref": "./settings.patch.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "settings.patch" },
        "agent": { "const": "project-build" },
        "execution_mode": { "type": "string", "enum": ["simulated", "real"] }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/editor.placement.proof_only.args.schema.json",
  "title": "editor.placement.proof_only args",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "candidate_id",
    "candidate_label",
    "staged_source_relative_path",
    "target_level_relative_path",
    "target_entity_name",
    "stage_write_evidence_reference",
    "stage_write_readback_reference"
  ],
  "properties": {
    "candidate_id": { "type": "string", "minLength": 1 },
    "candidate_label": { "type": "string", "minLength": 1 },
    "staged_source_relative_path": { "type": "string", "minLength": 1 },
    "target_level_relative_path": { "type": "string", "minLength": 1 },
    "target_entity_name": { "type": "string", "minLength": 1 },
    "target_component": { "type": "string", "minLength": 1 },
    "approval_state": {
      "type": "string",
      "enum": ["not-approved", "approved"]
    },
    "approval_note": { "type": "string" },
    "approval_session_id": { "type": "string", "minLength": 1 },
    "stage_write_corridor_name": { "type": "string", "minLength": 1 },
    "stage_write_evidence_reference": { "type": "string", "minLength": 1 },
    "stage_write_readback_reference": { "type": "string", "minLength": 1 },
    "stage_write_readback_status": {
      "type": "string",
      "enum": ["not_run", "blocked", "failed", "succeeded"]
    }
  }
}

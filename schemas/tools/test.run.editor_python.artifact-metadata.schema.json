{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/test.run.editor_python.artifact-metadata.schema.json",
  "title": "test.run.editor_python artifact metadata",
  "allOf": [
    {
      "$ref": "./test.run.editor_python.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "test.run.editor_python" },
        "agent": { "const": "validation" },
        "execution_mode": { "const": "simulated" }
      }
    }
  ]
}

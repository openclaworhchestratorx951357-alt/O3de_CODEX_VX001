{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/validation.report.intake.artifact-metadata.schema.json",
  "title": "validation.report.intake artifact metadata",
  "allOf": [
    {
      "$ref": "./validation.report.intake.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "validation.report.intake" },
        "agent": { "const": "validation" },
        "execution_mode": {
          "type": "string",
          "enum": ["simulated", "real"]
        }
      }
    }
  ]
}

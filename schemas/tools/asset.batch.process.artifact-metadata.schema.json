{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/asset.batch.process.artifact-metadata.schema.json",
  "title": "asset.batch.process artifact metadata",
  "allOf": [
    {
      "$ref": "./asset.batch.process.execution-details.schema.json"
    },
    {
      "type": "object",
      "required": [
        "tool",
        "agent",
        "execution_mode",
        "adapter_family",
        "adapter_mode",
        "adapter_contract_version"
      ],
      "properties": {
        "tool": { "const": "asset.batch.process" },
        "agent": { "const": "asset-pipeline" },
        "execution_mode": { "const": "simulated" }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/test.tiaf.sequence.result.schema.json",
  "title": "test.tiaf.sequence result",
  "allOf": [
    { "$ref": "../dispatch-result.schema.json" },
    {
      "type": "object",
      "properties": {
        "tool": { "const": "test.tiaf.sequence" },
        "approval_class": { "const": "test_execute" },
        "execution_mode": {
          "type": "string",
          "enum": ["simulated", "real"]
        },
        "simulated": { "type": "boolean" }
      }
    }
  ]
}

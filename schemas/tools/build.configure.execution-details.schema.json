{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/build.configure.execution-details.schema.json",
  "title": "build.configure execution details",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "inspection_surface",
    "execution_boundary"
  ],
  "properties": {
    "inspection_surface": {
      "type": "string",
      "enum": ["simulated", "build_configure_preflight"]
    },
    "execution_boundary": { "type": "string", "minLength": 1 },
    "adapter_family": { "type": "string", "minLength": 1 },
    "adapter_mode": { "type": "string", "minLength": 1 },
    "adapter_contract_version": { "type": "string", "minLength": 1 },
    "real_path_available": { "type": "boolean" },
    "fallback_reason": { "type": "string", "minLength": 1 },
    "project_manifest_path": { "type": "string", "minLength": 1 },
    "manifest_keys": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "project_name": { "type": "string", "minLength": 1 },
    "plan_details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

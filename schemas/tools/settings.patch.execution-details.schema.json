{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/settings.patch.execution-details.schema.json",
  "title": "settings.patch execution details",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "inspection_surface",
    "execution_boundary",
    "simulated"
  ],
  "properties": {
    "inspection_surface": {
      "type": "string",
      "enum": ["simulated", "settings_patch_preflight", "settings_patch_mutation"]
    },
    "execution_boundary": { "type": "string", "minLength": 1 },
    "simulated": { "type": "boolean" },
    "adapter_family": { "type": "string", "minLength": 1 },
    "adapter_mode": { "type": "string", "minLength": 1 },
    "adapter_contract_version": { "type": "string", "minLength": 1 },
    "real_path_available": { "type": "boolean" },
    "fallback_category": { "type": "string", "minLength": 1 },
    "fallback_reason": { "type": "string", "minLength": 1 },
    "project_root_path": { "type": "string", "minLength": 1 },
    "expected_project_manifest_path": { "type": "string", "minLength": 1 },
    "expected_project_manifest_relative_path": { "type": "string", "minLength": 1 },
    "project_manifest_path": { "type": "string", "minLength": 1 },
    "project_manifest_relative_path": {
      "type": ["string", "null"]
    },
    "project_manifest_read_mode": { "type": "string", "minLength": 1 },
    "project_manifest_source_of_truth": { "type": "string", "minLength": 1 },
    "project_manifest_workspace_local": { "type": "boolean" },
    "project_manifest_within_project_root": { "type": "boolean" },
    "project_name": { "type": ["string", "null"] },
    "registry_path": { "type": "string", "minLength": 1 },
    "operation_count": { "type": "number" },
    "supported_operation_count": { "type": "number" },
    "unsupported_operation_count": { "type": "number" },
    "admitted_registry_path": { "type": "string", "minLength": 1 },
    "admitted_manifest_paths": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "backup_target": { "type": "string", "minLength": 1 },
    "backup_created": { "type": "boolean" },
    "mutation_ready": { "type": "boolean" },
    "plan_details": {
      "type": "object",
      "additionalProperties": true
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/tools/test.visual.diff.execution-details.schema.json",
  "title": "test.visual.diff execution details",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "inspection_surface",
    "execution_boundary",
    "simulated"
  ],
  "properties": {
    "inspection_surface": {
      "type": "string",
      "enum": ["simulated", "artifact_file_comparison"]
    },
    "execution_boundary": { "type": "string", "minLength": 1 },
    "simulated": { "type": "boolean" },
    "adapter_family": { "type": "string", "minLength": 1 },
    "adapter_mode": { "type": "string", "minLength": 1 },
    "adapter_contract_version": { "type": "string", "minLength": 1 },
    "real_path_available": { "type": "boolean" },
    "comparison_read_mode": { "type": "string", "minLength": 1 },
    "baseline_artifact_id": { "type": "string", "minLength": 1 },
    "candidate_artifact_id": { "type": "string", "minLength": 1 },
    "threshold_requested": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "threshold_applied": { "type": "boolean" },
    "threshold_unavailable_reason": { "type": ["string", "null"], "minLength": 1 },
    "inspection_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "unavailable_evidence": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "baseline_resolution_status": { "type": "string", "minLength": 1 },
    "baseline_artifact_found": { "type": "boolean" },
    "baseline_local_path_resolved": { "type": ["string", "null"], "minLength": 1 },
    "baseline_file_exists": { "type": "boolean" },
    "baseline_file_readable": { "type": "boolean" },
    "baseline_content_type": { "type": ["string", "null"], "minLength": 1 },
    "baseline_extension": { "type": ["string", "null"], "minLength": 1 },
    "baseline_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "baseline_sha256": { "type": ["string", "null"], "minLength": 1 },
    "baseline_image_decode_attempted": { "type": "boolean" },
    "baseline_image_decode_substrate_available": { "type": "boolean" },
    "baseline_image_decode_status": { "type": "string", "minLength": 1 },
    "baseline_image_decodable": { "type": "boolean" },
    "baseline_image_width": { "type": ["integer", "null"], "minimum": 0 },
    "baseline_image_height": { "type": ["integer", "null"], "minimum": 0 },
    "baseline_image_mode": { "type": ["string", "null"], "minLength": 1 },
    "baseline_image_channel_count": { "type": ["integer", "null"], "minimum": 0 },
    "baseline_image_decode_unavailable_reason": { "type": ["string", "null"], "minLength": 1 },
    "candidate_resolution_status": { "type": "string", "minLength": 1 },
    "candidate_artifact_found": { "type": "boolean" },
    "candidate_local_path_resolved": { "type": ["string", "null"], "minLength": 1 },
    "candidate_file_exists": { "type": "boolean" },
    "candidate_file_readable": { "type": "boolean" },
    "candidate_content_type": { "type": ["string", "null"], "minLength": 1 },
    "candidate_extension": { "type": ["string", "null"], "minLength": 1 },
    "candidate_size_bytes": { "type": ["integer", "null"], "minimum": 0 },
    "candidate_sha256": { "type": ["string", "null"], "minLength": 1 },
    "candidate_image_decode_attempted": { "type": "boolean" },
    "candidate_image_decode_substrate_available": { "type": "boolean" },
    "candidate_image_decode_status": { "type": "string", "minLength": 1 },
    "candidate_image_decodable": { "type": "boolean" },
    "candidate_image_width": { "type": ["integer", "null"], "minimum": 0 },
    "candidate_image_height": { "type": ["integer", "null"], "minimum": 0 },
    "candidate_image_mode": { "type": ["string", "null"], "minLength": 1 },
    "candidate_image_channel_count": { "type": ["integer", "null"], "minimum": 0 },
    "candidate_image_decode_unavailable_reason": { "type": ["string", "null"], "minLength": 1 },
    "decoded_image_inputs": { "type": "boolean" },
    "comparison_attempted": { "type": "boolean" },
    "comparison_available": { "type": "boolean" },
    "comparison_method": { "type": ["string", "null"], "minLength": 1 },
    "comparison_status": { "type": "string", "minLength": 1 },
    "byte_identical": { "type": ["boolean", "null"] },
    "file_size_delta_bytes": { "type": ["integer", "null"] },
    "content_type_match": { "type": ["boolean", "null"] },
    "image_like_inputs": { "type": "boolean" },
    "visual_metric_input_compatible": { "type": "boolean" },
    "visual_metric_color_space": { "type": ["string", "null"], "minLength": 1 },
    "visual_metric_total_pixels": { "type": ["integer", "null"], "minimum": 0 },
    "visual_metric_matching_pixels": { "type": ["integer", "null"], "minimum": 0 },
    "visual_metric_mismatched_pixels": { "type": ["integer", "null"], "minimum": 0 },
    "visual_metric_available": { "type": "boolean" },
    "visual_metric_name": { "type": ["string", "null"], "minLength": 1 },
    "visual_metric_value": { "type": ["number", "null"] },
    "visual_metric_unavailable_reason": { "type": "string", "minLength": 1 },
    "fallback_category": { "type": "string", "minLength": 1 },
    "fallback_reason": { "type": "string", "minLength": 1 }
  }
}
